# Port bindings on the host
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Shared Docker network name that proxied containers must join.
# All stacks that want caddy to proxy them should set this same value
# and declare the network as external.
CADDY_INGRESS_NETWORK=caddy

# Email for ACME/Let's Encrypt registration.
ACME_EMAIL=you@example.com

# Cloudflare API token for ACME DNS-01 challenges (required when sites are
# behind the Cloudflare proxy). Create a scoped token: Zone:DNS:Edit + Zone:Read
# for the zones you serve. Keep this OUT of the repo — real value goes in .env
# or Komodo's secret store only.
CLOUDFLARE_API_TOKEN=cf-token-with-zone-dns-edit

# Optional: pre-built image name to use instead of building locally.
# CADDY_IMAGE=ghcr.io/youruser/caddy-docker-proxy-cloudflare:latest
