# Host address the Core UI port binds to. Defaults to all interfaces (0.0.0.0).
# Set to a specific IP (e.g. a Tailscale 100.x address) to keep Komodo off the
# public internet and reachable only over your private network.
KOMODO_BIND=0.0.0.0

# Komodo Core UI port
KOMODO_PORT=9120

# Your Komodo URL (used in UI links, notifications, webhooks)
KOMODO_HOST=http://komodo.yourdomain.com
KOMODO_TITLE=Komodo

# Optional: expose the UI via Caddy at this hostname, gated to the Tailscale
# network only (tailnet-sourced requests reach the UI; everyone else gets a 403).
# Point this hostname's DNS at your Tailscale IP (DNS-only). Leave unset to keep
# Komodo reachable solely on the bound port above.
KOMODO_DOMAIN=
CADDY_INGRESS_NETWORK=caddy

# Database credentials. FerretDB v2 stores data in a DocumentDB-flavoured
# Postgres backend; these are shared by Postgres, FerretDB and Komodo Core.
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=CHANGE_ME_generate_a_strong_db_password

# REQUIRED — generate strong random values before first run:
#   openssl rand -hex 32
KOMODO_PASSKEY=CHANGE_ME_generate_a_strong_passphrase
KOMODO_JWT_SECRET=CHANGE_ME_generate_a_strong_secret
KOMODO_WEBHOOK_SECRET=CHANGE_ME_generate_a_strong_webhook_secret

# First-run auth. Local login + a seeded admin so you can get in; registration
# is locked afterwards (only the admin can create users from the UI).
KOMODO_LOCAL_AUTH=true
KOMODO_INIT_ADMIN_USERNAME=admin
KOMODO_INIT_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
KOMODO_DISABLE_USER_REGISTRATION=true
KOMODO_ENABLE_NEW_USERS=false

# Auto-register the local periphery as a managed server (address + display name).
KOMODO_FIRST_SERVER=https://komodo-periphery:8120
KOMODO_FIRST_SERVER_NAME=Local
