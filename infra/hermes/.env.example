# Hermes Agent — hostname for the supervised dashboard (TAILSCALE-GATED at the Caddy edge; off-tailnet = 403).
HERMES_DOMAIN=hermes.example.com
CADDY_INGRESS_NETWORK=caddy

# Pin the image (default: nousresearch/hermes-agent:latest).
HERMES_IMAGE=nousresearch/hermes-agent:latest

HERMES_TIMEZONE=America/Toronto

# Inner dashboard auth (defense-in-depth behind the Caddy forward_auth). Store the password in your
# secret manager, not here. To use Authentik SSO directly instead, leave basic auth and additionally
# create an Authentik OIDC provider, then set HERMES_DASHBOARD_OIDC_ISSUER + _CLIENT_ID in the stack.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=

# Terminal sandbox backend: local (runs in this container) | docker | ssh | modal | daytona.
HERMES_TERMINAL_ENV=local

# LLM provider — DeepSeek (native). Real value via secret manager.
DEEPSEEK_API_KEY=

# Optional messaging channels (leave empty to disable).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=

# Optional scoped dev/vault mounts (host paths) — leave unset until ready.
# OBSIDIAN_VAULT_PATH=/path/to/nextcloud/shared/obsidian
# HERMES_PROJECTS_DIR=/path/to/scoped/projects
