# Public hostname for the Beszel hub (gated by Authentik forward_auth via Caddy).
BESZEL_DOMAIN=beszel.example.com
CADDY_INGRESS_NETWORK=caddy

# Pin the image tag (default: latest).
BESZEL_TAG=latest

# Agent listen port (host networking).
BESZEL_AGENT_PORT=45876

# The hub's SSH PUBLIC key — copy it from the hub on first run:
#   docker exec beszel cat /beszel_data/id_ed25519.pub
# (or from the "Add System" dialog in the hub UI). Not a secret.
BESZEL_AGENT_KEY=
