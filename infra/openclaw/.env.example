# OpenClaw — hostname for the gateway dashboard (TAILSCALE-GATED at the Caddy edge; off-tailnet = 403).
OPENCLAW_DOMAIN=openclaw.example.com
CADDY_INGRESS_NETWORK=caddy

# Pin the image (default: ghcr.io/openclaw/openclaw:latest).
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Gateway token — authenticates the dashboard + control plane. Generate a strong random value
# and store it in your secret manager (NOT here). Treat like a password.
OPENCLAW_GATEWAY_TOKEN=

# Headless bring-up + agent sandboxing.
OPENCLAW_SKIP_ONBOARDING=1
OPENCLAW_SANDBOX=1

# LLM provider — DeepSeek (OpenAI-compatible; base url https://api.deepseek.com). Real value via
# secret manager. Configure the provider profile during the one-time onboarding.
DEEPSEEK_API_KEY=

# Optional scoped dev/vault mounts (host paths) — leave unset until ready.
# OBSIDIAN_VAULT_PATH=/path/to/nextcloud/shared/obsidian
# OPENCLAW_PROJECTS_DIR=/path/to/scoped/projects
