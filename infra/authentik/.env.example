# Authentik stack variables
PG_USER=authentik
PG_PASS=change-me
AUTHENTIK_SECRET_KEY=replace-with-a-long-random-secret

# Domain Caddy will serve Authentik on (used by the caddy label).
AUTHENTIK_DOMAIN=auth.example.com

# Shared Caddy ingress network name (must match the caddy-docker-proxy stack).
CADDY_INGRESS_NETWORK=caddy
