# Public hostname for Homepage (gated by Authentik forward_auth via Caddy).
HOMEPAGE_DOMAIN=home.example.com
CADDY_INGRESS_NETWORK=caddy

# Pin the image tag (default: latest).
HOMEPAGE_TAG=latest

# Host path to the restic backup status JSON (written by deployments/bin/backup.sh),
# served read-only to Homepage's customapi widget.
BACKUP_STATUS_FILE=/home/alien/lab/deployments/backup-status.json
