# Hostname Caddy serves Termix on (single host). Termix is exposed Tailscale-only:
# pair this with a DNS-only A record TERMIX_DOMAIN -> your tailnet IP.
TERMIX_DOMAIN=ssh.example.com

# Shared Caddy ingress network (must match the caddy-docker-proxy stack).
CADDY_INGRESS_NETWORK=caddy

# Image tags.
TERMIX_TAG=latest
GUACD_TAG=1.6.0

# Termix listener and guacd sidecar wiring.
TERMIX_PORT=8080
GUACD_HOST=guacd
