# Public domain Caddy serves Nextcloud on (used by the caddy label).
NEXTCLOUD_DOMAIN=cloud.example.com

# Shared Caddy ingress network (must match the caddy-docker-proxy stack).
CADDY_INGRESS_NETWORK=caddy

# AIO admin/setup UI (HTTPS, self-signed). Bind to a private address — do NOT
# expose this publicly. e.g. AIO_ADMIN_BIND=<tailscale-ip>.
AIO_ADMIN_PORT=18080
AIO_ADMIN_BIND=0.0.0.0

# Port AIO's apache listens on; Caddy proxies to nextcloud-aio-apache:<this>.
# apache joins CADDY_INGRESS_NETWORK (APACHE_ADDITIONAL_NETWORK) so no public
# host port is needed; the host binding is kept on localhost.
NEXTCLOUD_APACHE_PORT=11000
NEXTCLOUD_APACHE_IP_BINDING=127.0.0.1

# Host path for Nextcloud ncdata.
# Set this BEFORE first run — changing it later requires a full data migration.
NEXTCLOUD_DATADIR=/mnt/nextcloud/data

# Obsidian shared vault path (subdirectory of NEXTCLOUD_DATADIR).
# Other containers that need access to Obsidian vaults should mount this same path.
# Create it AFTER initial AIO setup (AIO wants an empty datadir on first run):
#   mkdir -p $NEXTCLOUD_DATADIR/shared/obsidian
OBSIDIAN_VAULT_PATH=/mnt/nextcloud/data/shared/obsidian

# Startup apps and PHP/runtime tuning
NEXTCLOUD_STARTUP_APPS=deck twofactor_totp tasks calendar contacts notes
NEXTCLOUD_UPLOAD_LIMIT=100G
NEXTCLOUD_MAX_TIME=7200
NEXTCLOUD_MEMORY_LIMIT=1024M

# Behind Cloudflare + Caddy the built-in domain check can't reach AIO; keep true.
SKIP_DOMAIN_VALIDATION=true
