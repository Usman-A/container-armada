# AIO admin UI
AIO_ADMIN_PORT=18080

# Caddy proxies to this host IP and port
NEXTCLOUD_APACHE_PORT=11000
NEXTCLOUD_APACHE_IP_BINDING=0.0.0.0

# Host path for Nextcloud ncdata.
# Set this BEFORE first run — changing it later requires a full data migration.
NEXTCLOUD_DATADIR=/mnt/nextcloud/data

# Obsidian shared vault path (subdirectory of NEXTCLOUD_DATADIR).
# Other containers that need access to Obsidian vaults should mount this same path.
# Create it before first run: mkdir -p $NEXTCLOUD_DATADIR/shared/obsidian
OBSIDIAN_VAULT_PATH=/mnt/nextcloud/data/shared/obsidian

# Startup apps and PHP/runtime tuning
NEXTCLOUD_STARTUP_APPS=deck twofactor_totp tasks calendar contacts notes
NEXTCLOUD_UPLOAD_LIMIT=100G
NEXTCLOUD_MAX_TIME=7200
NEXTCLOUD_MEMORY_LIMIT=1024M

# Usually keep this false
SKIP_DOMAIN_VALIDATION=false
