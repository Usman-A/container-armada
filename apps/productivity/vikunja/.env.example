VIKUNJA_DB_PASSWORD=change-me
VIKUNJA_SERVICE_PUBLICURL=https://vikunja.example.com

# Domain Caddy will serve this app on (used by the caddy label).
VIKUNJA_DOMAIN=vikunja.example.com

# Shared Caddy ingress network name (must match the caddy-docker-proxy stack).
CADDY_INGRESS_NETWORK=caddy

# Image tag — pinned for predictable auto-deploys.
VIKUNJA_TAG=0.24.6

VIKUNJA_OIDC_AUTH_URL=https://auth.example.com/application/o/vikunja/
VIKUNJA_OIDC_CLIENT_ID=replace-me
VIKUNJA_OIDC_CLIENT_SECRET=replace-me
VIKUNJA_AUTHENTIK_ONLY=false # flag that if set true, only allows authentik auth
